.PHONY: build test run lint tidy docker-build

build:
	go build -o bin/escrow-service .

test:
	go test ./... -v -race

run:
	go run .

tidy:
	go mod tidy

lint:
	golangci-lint run ./...

docker-build: tidy
	docker build -t estateiq/escrow-service:latest .

docker-run:
	docker run --rm -p 50063:50063 --env-file .env estateiq/escrow-service:latest
